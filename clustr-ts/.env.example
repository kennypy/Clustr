# ── Proxmox: your default cluster ───────────────────────────────────────────
PROXMOX_HOST=192.168.1.10
PROXMOX_USER=root@pam
PROXMOX_TOKEN_NAME=clustr
PROXMOX_TOKEN_VALUE=                 # the API token secret
PROXMOX_VERIFY_SSL=false             # PVE's default cert is self-signed

# ── Remote connector auth (REQUIRED to expose remotely) ─────────────────────
# This single password is the whole gate to your cluster over the internet, so
# use a LONG, RANDOM passphrase (16+ chars; e.g. `openssl rand -base64 24`).
# Clustr throttles guesses, but a weak secret is still the weak link. With this
# set, Clustr runs its own OAuth and protects /mcp; without it, the container
# refuses to start (fail closed).
CLUSTR_AUTH_PASSWORD=
CLUSTR_AUTH_USERNAME=admin
# The public HTTPS URL your tunnel serves (no trailing slash). MUST match the
# Cloudflare tunnel hostname, or OAuth discovery will advertise the wrong URLs.
CLUSTR_PUBLIC_URL=https://clustr.example.com

# ── Cloudflare Tunnel ───────────────────────────────────────────────────────
# Create a tunnel in the Cloudflare dashboard, route its hostname to
# http://clustr:8080, and paste the tunnel token here.
TUNNEL_TOKEN=

# ── Optional: additional Proxmox clusters (multi-host) ──────────────────────
# CLUSTR_ENDPOINTS=[{"name":"office","host":"10.0.0.5","tokenName":"clustr","tokenValue":"…"}]
# CLUSTR_ENDPOINTS_FILE=/data/endpoints.json
