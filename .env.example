# =============================================================================
# CLUSTR - Proxmox MCP Server
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Proxmox Connection ---
PROXMOX_HOST=192.168.1.1          # IP or hostname of your Proxmox node
PROXMOX_PORT=8006                  # Default Proxmox API port
PROXMOX_USER=root@pam              # Proxmox user (realm included)
PROXMOX_TOKEN_NAME=clustr          # API token name (created in Proxmox UI)
PROXMOX_TOKEN_VALUE=               # API token secret value
PROXMOX_VERIFY_SSL=false           # Set true in production with valid cert

# --- MCP Server ---
# Bind address. Defaults to 127.0.0.1 (loopback only) when unset — the safe
# default for a pip/local install. Only set this to 0.0.0.0 if something in
# front (reverse proxy, Cloudflare Tunnel) terminates auth/TLS, or you are
# running in Docker (the image already binds 0.0.0.0 inside the container and
# compose publishes it to 127.0.0.1 on the host).
# MCP_HOST=127.0.0.1
MCP_PORT=8080                      # HTTP port
MCP_LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR

# Public, canonical HTTPS URL of this server when exposed via a reverse proxy /
# Cloudflare Tunnel. Used in the OAuth protected-resource metadata, and its host
# is added to the transport-security (DNS-rebinding) allow-list automatically.
# MCP_PUBLIC_URL=https://clustr.example.com

# Extra Host header values to allow (comma-separated). Requests whose Host is
# not allow-listed are rejected with 421. Loopback (localhost / 127.0.0.1, any
# port) is always allowed. Add your LAN IP or hostname here if clients connect
# to the server directly, e.g.:
# MCP_ALLOWED_HOSTS=192.168.1.50,clustr.lan
# A bare hostname allows any port; include :port to pin one.

# Trust X-Forwarded-Proto / X-Forwarded-Host from a reverse proxy when deriving
# the server's canonical URL (only when MCP_PUBLIC_URL is unset). Leave false
# unless a trusted proxy sets these headers — otherwise clients can spoof them.
# MCP_TRUST_PROXY=false

# --- OAuth 2.1 (DISABLED by default — set OAUTH_ENABLED=true to activate) ---
# When disabled, the server operates with no auth on the MCP endpoint.
# Configure network-level access control (firewall/Cloudflare) instead.
# When enabled, all MCP requests require a valid Bearer token.
OAUTH_ENABLED=false

# OAuth provider settings (only required when OAUTH_ENABLED=true)
OAUTH_ISSUER=https://your-auth-server.example.com
OAUTH_CLIENT_ID=clustr
OAUTH_CLIENT_SECRET=
OAUTH_AUDIENCE=clustr-mcp
# JWKS URI is auto-discovered from OAUTH_ISSUER/.well-known/openid-configuration
# Override here if your provider does not support discovery:
# OAUTH_JWKS_URI=https://your-auth-server.example.com/.well-known/jwks.json
